# EKIP - Enterprise Knowledge Intelligence Platform
# Copy this file to ".env" and fill in values.
# Never commit real secrets. Use Azure Key Vault in production.

# ---- App runtime ----
EKIP_ENV=local
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000
ALLOWED_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Optional for AUTH_MODE=dev_token
NEXT_PUBLIC_DEV_AUTH_TOKEN=

# ---- Local app data ----
DATA_DIR=/app/data
UPLOADS_DIR=/app/data/uploads
SQLITE_PATH=/app/data/ekip.db

# ---- Provider switches ----
# sqlite|cosmos
EKIP_STATE_PROVIDER=sqlite
# redis|servicebus
EKIP_QUEUE_PROVIDER=redis
# local|azureblob
EKIP_STORAGE_PROVIDER=local
# qdrant|azuresearch
EKIP_INDEX_PROVIDER=qdrant

# ---- Local adapter defaults (optional) ----
REDIS_URL=redis://redis:6379/0
REDIS_INGEST_QUEUE=ekip:ingest
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=ekip_chunks

# ---- Azure OpenAI (used by local dev too, if provided) ----
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-large

# ---- Microsoft Foundry / Agent Framework (optional) ----
AZURE_AI_PROJECT_ENDPOINT=
AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME=
# Enable MCP tool loop in ORCHESTRATOR_MODE=maf
AZURE_MCP_ENABLED=false
# Command used to start Azure MCP server (stdio mode)
AZURE_MCP_SERVER_COMMAND=azmcp
# JSON array of args, example:
# ["server","start","--transport","stdio"]
AZURE_MCP_SERVER_ARGS=["server","start"]
# Optional comma-separated allow list of tools. Empty = all discovered tools.
AZURE_MCP_TOOL_NAMES=
# Optional per-tool argument overrides as JSON object.
# Supports template placeholders: {{question}}, {{conversation_id}}
# Example: {"search_knowledge":{"query":"{{question}}","conversation_id":"{{conversation_id}}"}}
AZURE_MCP_TOOL_ARGUMENTS_JSON={}
AZURE_MCP_TOOL_MAX_CALLS=4
AZURE_MCP_TOOL_TIMEOUT_SECONDS=30

# ---- Azure Blob Storage (raw docs) ----
# Option A (local dev): connection string
AZURE_STORAGE_CONNECTION_STRING=
# Option B (Azure): account URL + managed identity
AZURE_STORAGE_ACCOUNT_URL=https://<storageaccount>.blob.core.windows.net
AZURE_STORAGE_CONTAINER_RAW=raw

# ---- Azure Service Bus (ingest queue) ----
# Option A (local dev): connection string
AZURE_SERVICEBUS_CONNECTION_STRING=
# Option B (Azure): namespace FQDN + managed identity
AZURE_SERVICEBUS_FQDN=<namespace>.servicebus.windows.net
AZURE_SERVICEBUS_QUEUE=doc-ingest

# ---- Azure AI Search (vector + keyword index) ----
AZURE_SEARCH_ENDPOINT=https://<searchservice>.search.windows.net
# Admin key for local dev; in Azure prefer managed identity and leave this empty
AZURE_SEARCH_ADMIN_KEY=
AZURE_SEARCH_INDEX_NAME=ekip-knowledge
# text-embedding-3-large vector dimension
AZURE_SEARCH_VECTOR_DIM=3072

# ---- Azure Cosmos DB ----
AZURE_COSMOS_ENDPOINT=
AZURE_COSMOS_KEY=
AZURE_COSMOS_DB=ekip
AZURE_COSMOS_CONTAINER_CONVERSATIONS=conversations
AZURE_COSMOS_CONTAINER_INGEST_JOBS=ingest_jobs
AZURE_COSMOS_CONTAINER_AGENT_LOGS=agent_logs

# ---- Auth / RBAC ----
# disabled|dev_token|azure_ad
AUTH_MODE=disabled
DEV_AUTH_TOKEN=dev-token-change-me
# CSV roles applied in AUTH_MODE=disabled or when X-EKIP-ROLES is omitted in dev_token mode
DEV_AUTH_DEFAULT_ROLES=Admin,Analyst,Viewer
# Azure AD audience for API tokens (usually App Registration client ID or api://<app-id>)
AZURE_AD_AUDIENCE=

# ---- Azure identity / infra metadata ----
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-ekip-dev
AZURE_LOCATION=westeurope
AZURE_KEYVAULT_NAME=

# Optional naming fields used in infra scripts or portal lookups
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=documents
AZURE_SERVICEBUS_NAMESPACE=

# ---- Orchestrator mode ----
# deterministic|maf
ORCHESTRATOR_MODE=deterministic







